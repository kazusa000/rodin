@PACKAGE_INIT@

# Use modern Boost finding mechanism (CMake 3.30+)
if(POLICY CMP0167)
  cmake_policy(SET CMP0167 NEW)
endif()

include(CMakeFindDependencyMacro)

# Eigen3 - We originally developed with 3.4, but newer versions (e.g., 5.x) are compatible
# Note: Not specifying version to allow flexibility with system installations
find_dependency(Boost 1.74 REQUIRED COMPONENTS filesystem serialization)
find_dependency(HDF5 REQUIRED COMPONENTS C)
find_dependency(Threads REQUIRED)
find_dependency(Eigen3 REQUIRED)

# Find optional dependencies if they were used during build
if(@RODIN_MULTITHREADED@)
  find_dependency(Threads REQUIRED)
endif()

if(@RODIN_USE_OPENMP@)
  find_dependency(OpenMP REQUIRED)
endif()

if(@RODIN_USE_MPI@)
  find_dependency(Boost 1.74 REQUIRED COMPONENTS mpi)
endif()

if(@RODIN_USE_PETSC@)
  find_dependency(PETSc REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/RodinTargets.cmake")
